# Compiled binaries / build output
bin/
*.exe
*.dll
*.so
*.dylib

# Stray module-named binaries built directly inside app directories (e.g. by
# `go build .` run inside apps/eth-signer-mcp/ instead of from the repo root).
# The canonical output location is bin/ (via `make build`).
apps/*/eth-signer-mcp
apps/*/eth-signer-mcp.exe

# Test & coverage artifacts
*.test
*.out
coverage.*
profile.out

# Dependency vendoring
vendor/

# Go workspace local sum file (go.work itself is tracked)
go.work.sum

# Editor / IDE
.idea/
.vscode/
*.swp
*~

# OS cruft
.DS_Store
Thumbs.db

# Node / npm (regen-vectors-ethers.mjs tooling — not committed)
scripts/node_modules/
scripts/package.json
scripts/package-lock.json
