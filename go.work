go 1.26

// toolchain pins the patch release used to build/test the workspace. Kept at the
// latest 1.26.x to clear standard-library security advisories (govulncheck gate);
// bump as new Go patch releases land. The `go 1.26` line above is the language
// version; this is the concrete toolchain.
toolchain go1.26.4

// This is a multi-module Go workspace.
//
// Add a module with the Makefile, which scaffolds it and runs `go work use`:
//
//	make new-app name=foo   -> creates apps/foo (module .../apps/foo)
//	make new-lib name=bar   -> creates libs/bar (module .../libs/bar)
//
// Go manages the `use ( ... )` block below automatically.

use (
	./apps/eth-signer-mcp
	// scripts/demo is a demo-only module (stdio + HTTP fallback clients).
	// It is NOT under apps/ or libs/, so it is outside Makefile discovery:
	// `make lint`, `make test`, and `make build` do NOT cover it.
	// Added by hand deliberately — see docs/demo.md for usage.
	./scripts/demo
)
